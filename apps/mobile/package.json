    "@react-navigation/native-stack": "^7.12.0",
    "@warden/contracts": "workspace:*",
    "@wokcito/ffmpeg-kit-react-native": "^6.1.2",
    "expo": "~54.0.33",
    "expo-crypto": "~15.0.8",
    "expo-document-picker": "^14.0.8",
