# Firebase configuration (from Firebase Console > Project Settings > General > Your apps)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Required Firebase services:
# - Authentication: Enable Email/Password sign-in method
# - Firestore: Create a "users" collection with documents keyed by user UID
#   Each user document must have a boolean field "isPaid" (true/false)
#   for subscription validation to work
