# Firebase configuration (from Firebase Console > Project Settings > General > Your apps)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google sign-in: the Web client ID auto-created by Firebase for the project.
# Find it in Google Cloud Console > APIs & Services > Credentials > "Web client
# (auto created by Google Service)" or in Firebase Console > Project Settings >
# General > your Web SDK config. NOTE: this is the Web client ID, not the Android
# client ID — the native @react-native-google-signin SDK requires the Web ID to
# mint an idToken that Firebase Auth will accept.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# DEV ONLY: set to "true" to bypass the login screen and subscription gate.
# Injects a fake authenticated paid user at app boot. Remove (or set to "false")
# before shipping — this disables all access control.
EXPO_PUBLIC_AUTH_BYPASS=false

# Required Firebase services:
# - Authentication: Enable Email/Password and Google sign-in methods
# - Firestore: Create a "users" collection with documents keyed by user UID
#   Each user document must have a boolean field "isPaid" (true/false)
#   for subscription validation to work
# - Android only: commit google-services.json at apps/mobile/google-services.json
#   (NOT android/app/ — that tree is git-ignored and wiped by `expo prebuild`).
#   It is referenced via app.json `expo.android.googleServicesFile` and is a
#   client config asset, NOT a secret — it is committed (Firebase security relies
#   on Firestore rules + App Check, not on hiding this file). Register the app's
#   SHA-1 (and SHA-256 for release) fingerprint in Firebase Console.
