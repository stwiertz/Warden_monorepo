# node-linker=hoisted is REQUIRED for the Expo / Metro app at apps/mobile.
# Metro's resolver with disableHierarchicalLookup=true (the canonical Expo monorepo config)
# cannot walk into pnpm's nested .pnpm/<hash>/node_modules to resolve transitive deps
# like expo-modules-core. Hoisted node_modules is Expo's documented escape hatch.
# Trade-off: defeats pnpm's strictness against phantom deps, but Metro/RN ergonomics win.
node-linker=hoisted
