{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Warden React Native (Expo)",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "jsx": "react-native",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "noEmit": true,
    "types": ["jest", "node"]
  }
}
