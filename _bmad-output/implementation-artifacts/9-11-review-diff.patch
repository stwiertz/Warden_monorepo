-        s_t_cv / max(float(np.mean(block[..., 1])), 1.0),
-        v_t_cv / max(float(np.mean(block[..., 2])), 1.0),
-    )
-    return float(min(1.0, min(margins) / _COVERAGE_STD_TARGET))
