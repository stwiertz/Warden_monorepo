-                             frame_shape=shape, source_cells=("v2.0/lobby",), stability_score=12.0)
-
-    def _other(blockA_hsv):
-        mh = np.full(shape, bg_hsv, dtype=np.float32)
-        mh[5:25, 8:33] = blockA_hsv
-        return mh
-
-    others = {
