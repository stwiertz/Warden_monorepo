-def _welford_init(shape) -> tuple[int, np.ndarray, np.ndarray]:
-    """``(count, mean, M2)`` zero-state on ``float64`` arrays of ``shape``."""
-    return (0, np.zeros(shape, dtype=np.float64), np.zeros(shape, dtype=np.float64))
