-def detect_frame_type(basename):
-    """Detect frame type ('score', 'start', 'end') from a filename, defaulting to 'score'."""
-    if re.search(r'_start[_.]', basename):
-        return 'start'
-    if re.search(r'_end[_.]', basename):
-        return 'end'
-    return 'score'
