-    if not shapes:
-        raise ValueError("no shapes")
-    counter = Counter(tuple(int(d) for d in s) for s in shapes)
-    best, _ = max(
-        counter.items(),
-        key=lambda kv: (kv[1], kv[0][0] * kv[0][1], kv[0]),
